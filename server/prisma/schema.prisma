generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id              String         @id @default(uuid()) @db.Uuid
  name            String         @db.VarChar(255)
  industry        String?        @db.VarChar(100)
  timezone        String         @default("UTC") @db.VarChar(50)
  status          TenantStatus   @default(ACTIVE)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime?      @db.Timestamptz(6)
  audit_logs      AuditLog[]
  expenses        Expense[]
  follow_up_tasks FollowUpTask[]
  interactions    Interaction[]
  lead_sources    LeadSource[]
  leads           Lead[]
  sales           Sale[]
  users           User[]

  @@map("tenants")
}

model User {
  id                     String         @id @default(uuid()) @db.Uuid
  tenant_id              String         @db.Uuid
  email                  String         @db.VarChar(255)
  password_hash          String         @db.VarChar(255)
  first_name             String         @db.VarChar(100)
  last_name              String         @db.VarChar(100)
  role                   UserRole       @default(STAFF)
  last_login_at          DateTime?      @db.Timestamptz(6)
  created_at             DateTime       @default(now()) @db.Timestamptz(6)
  updated_at             DateTime       @updatedAt @db.Timestamptz(6)
  deleted_at             DateTime?      @db.Timestamptz(6)
  reset_password_expires DateTime?      @db.Timestamptz(6)
  reset_password_token   String?        @db.VarChar(255)
  audit_logs             AuditLog[]
  tasks                  FollowUpTask[]
  interactions           Interaction[]
  assigned_leads         Lead[]
  tenant                 Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, email])
  @@index([tenant_id, email])
  @@map("users")
}

model LeadSource {
  id         String   @id @default(uuid()) @db.Uuid
  tenant_id  String   @db.Uuid
  name       String   @db.VarChar(100)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  leads      Lead[]

  @@index([tenant_id, is_active])
  @@map("lead_sources")
}

model Lead {
  id           String         @id @default(uuid()) @db.Uuid
  tenant_id    String         @db.Uuid
  source_id    String?        @db.Uuid
  assigned_to  String?        @db.Uuid
  first_name   String         @db.VarChar(100)
  last_name    String?        @db.VarChar(100)
  phone_number String         @db.VarChar(50)
  email        String?        @db.VarChar(255)
  service      String?        @db.VarChar(255)
  status       LeadStatus     @default(NEW)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @updatedAt @db.Timestamptz(6)
  deleted_at   DateTime?      @db.Timestamptz(6)
  description  String?
  expiry_date  DateTime?      @db.Timestamptz(6)
  tasks        FollowUpTask[]
  interactions Interaction[]
  assignee     User?          @relation(fields: [assigned_to], references: [id])
  source       LeadSource?    @relation(fields: [source_id], references: [id])
  tenant       Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sales        Sale[]

  @@index([tenant_id, phone_number])
  @@index([tenant_id, status])
  @@index([tenant_id, assigned_to])
  @@map("leads")
}

model Interaction {
  id         String          @id @default(uuid()) @db.Uuid
  tenant_id  String          @db.Uuid
  lead_id    String          @db.Uuid
  user_id    String?         @db.Uuid
  type       InteractionType
  notes      String?
  created_at DateTime        @default(now()) @db.Timestamptz(6)
  lead       Lead            @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant     Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user       User?           @relation(fields: [user_id], references: [id])

  @@index([tenant_id, lead_id, created_at(sort: Desc)])
  @@map("interactions")
}

model FollowUpTask {
  id           String     @id @default(uuid()) @db.Uuid
  tenant_id    String     @db.Uuid
  lead_id      String     @db.Uuid
  assigned_to  String     @db.Uuid
  due_date     DateTime   @db.Timestamptz(6)
  status       TaskStatus @default(PENDING)
  completed_at DateTime?  @db.Timestamptz(6)
  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  updated_at   DateTime   @updatedAt @db.Timestamptz(6)
  assignee     User       @relation(fields: [assigned_to], references: [id], onDelete: Cascade)
  lead         Lead       @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, assigned_to, due_date])
  @@index([tenant_id, lead_id])
  @@map("follow_up_tasks")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenant_id     String   @db.Uuid
  user_id       String?  @db.Uuid
  action        String   @db.VarChar(255)
  entity_type   String   @db.VarChar(100)
  entity_id     String   @db.Uuid
  previous_data Json?
  new_data      Json?
  ip_address    String?  @db.VarChar(45)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [user_id], references: [id])

  @@index([tenant_id, created_at(sort: Desc)])
  @@index([tenant_id, entity_type, entity_id])
  @@map("audit_logs")
}

model Sale {
  id             String        @id @default(uuid()) @db.Uuid
  tenant_id      String        @db.Uuid
  lead_id        String        @db.Uuid
  amount         Decimal       @db.Decimal(10, 2)
  type           SaleType      @default(MEMBERSHIP_PURCHASE)
  date           DateTime      @default(now()) @db.Timestamptz(6)
  created_at     DateTime      @default(now()) @db.Timestamptz(6)
  payment_method PaymentMethod @default(CASH)
  lead           Lead          @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  tenant         Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, date])
  @@map("sales")
}

model Expense {
  id         String          @id @default(uuid()) @db.Uuid
  tenant_id  String          @db.Uuid
  category   ExpenseCategory
  amount     Decimal         @db.Decimal(10, 2)
  notes      String?
  date       DateTime        @default(now()) @db.Timestamptz(6)
  created_at DateTime        @default(now()) @db.Timestamptz(6)
  tenant     Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, date])
  @@map("expenses")
}

enum UserRole {
  ADMIN
  STAFF
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  WON
  LOST
}

enum InteractionType {
  CALL
  WHATSAPP
  EMAIL
  MEETING
  WALK_IN
  NOTE
  STATUS_CHANGE
}

enum TaskStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum SaleType {
  MEMBERSHIP_PURCHASE
  MEMBERSHIP_RENEWAL
}

enum ExpenseCategory {
  RENT
  ELECTRICITY
  TRAINER_SALARY
  EQUIPMENT
  MAINTENANCE
  MARKETING
  INTERNET
  OTHER
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
}
